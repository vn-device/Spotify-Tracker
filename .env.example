# Example .env for spotify_most_played
# Set your Spotify app Client ID
SPOTIFY_CLIENT_ID=your_client_id_here

# Optional: redirect URI you registered in the Spotify Dashboard
# Defaults to http://127.0.0.1:8080/callback
SPOTIFY_REDIRECT_URI=http://127.0.0.1:8080/callback

# Optional: where token data will be stored (expand ~)
# Defaults to ~/.spotify_most_played.json
SPOTIFY_TOKEN_PATH=~/.spotify_most_played.json
